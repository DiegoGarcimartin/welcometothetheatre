# Copy this file to ".env" and fill in your key, then run the server.
#   cp .env.example .env
# Get the team key from Diego (Slack / 1Password) — never commit the real .env.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: voice the narrator with a cloud TTS instead of the browser voice.
# Leave all blank to use the browser voice. fish.audio is used if its key is set,
# otherwise ElevenLabs.

# fish.audio — set the key and it speaks like Chiquito by default (FISH_MODEL_ID
# defaults to the Chiquito community voice; change it for any other voice).
FISH_API_KEY=
# FISH_MODEL_ID=1f747932d1b947359760ad8b431cdf31
# FISH_BACKBONE=s1

# ElevenLabs — set the key + a voice id you are entitled to use.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
