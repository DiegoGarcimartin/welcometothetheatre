# Copy this file to ".env" and fill in your key, then run the server.
#   cp .env.example .env
# Get the team key from Diego (Slack / 1Password) — never commit the real .env.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: voice the narrator with ElevenLabs (real voices) instead of the
# browser voice. Leave blank to use the browser voice. Use a voice you are
# entitled to use — do not clone a real person without authorisation.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
